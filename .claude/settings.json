{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["cachebro", "codemogger"],
  "permissions": {
    "allow": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-lint.sh \"$TOOL_INPUT\"",
            "matcher": "git commit"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-push-test.sh \"$TOOL_INPUT\"",
            "matcher": "git push"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-index-update.sh"
          }
        ]
      }
    ]
  }
}
